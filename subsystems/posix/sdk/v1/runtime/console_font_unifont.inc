struct sx_console_glyph_range { unsigned int first; unsigned int last; unsigned int base; };
static const struct sx_console_glyph_range kConsoleGlyphRanges[] = {
    {0x0020, 0x00ff, 1},
    {0x2500, 0x257f, 225},
    {0x2580, 0x259f, 353},
};
static const int kConsoleGlyphRangeCount = 3;

/* Look up a codepoint, falling back to slot 0 (.notdef). */
static inline const unsigned char* sx_console_glyph(unsigned int cp) {
    int i;
    for (i = 0; i < kConsoleGlyphRangeCount; ++i) {
        if (cp >= kConsoleGlyphRanges[i].first && cp <= kConsoleGlyphRanges[i].last) {
            return kConsoleGlyphs[kConsoleGlyphRanges[i].base + (cp - kConsoleGlyphRanges[i].first)];
        }
    }
    return kConsoleGlyphs[0];
}
